generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  name                String
  clinicName          String?
  role                String               @default("THERAPIST")
  patientLicenses     Int                  @default(-1)
  crp                 String?
  crpStatus           String               @default("unverified")
  crpDocument         String?
  crpAcceptedTerms    Boolean              @default(false)
  crpSubmittedAt      DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  patients            Patient[]
  therapeuticSessions TherapeuticSession[]
}

model Patient {
  id                  String               @id @default(cuid())
  name                String
  birthDate           DateTime
  education           String?
  medications         String?
  therapeuticGoals    String?
  clinicalNotes       String?
  contact             String?
  guardian            String?
  cid                 String?
  diagnosis           String?
  pin                 String
  patientCode         String?              @unique
  theme               String               @default("CLINICAL")
  therapistId         String
  therapist           User                 @relation(fields: [therapistId], references: [id], onDelete: Restrict)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  trainingPlans       TrainingPlan[]
  exerciseConfigs     ExerciseConfig[]
  achievements        Achievement[]
  alerts              Alert[]
  therapeuticSessions TherapeuticSession[]
}

model TrainingPlan {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  domains         String
  sessionDuration Int      @default(30)
  frequency       Int      @default(3)
  isActive        Boolean  @default(true)
  exercises       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  exerciseId   String
  domain       String
  score        Float
  accuracy     Float
  reactionTime Float?
  difficulty   Int
  duration     Int
  completedAt  DateTime @default(now())
  metadata     String?
}

model ExerciseConfig {
  id                String    @id @default(cuid())
  patientId         String
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  exerciseId        String
  currentDifficulty Int       @default(1)
  totalAttempts     Int       @default(0)
  lastAttemptAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([patientId, exerciseId])
}

model Achievement {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())
  metadata    String?
}

model Alert {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LicenseCode {
  id                String    @id @default(cuid())
  code              String    @unique
  licenses          Int
  usedByTherapistId String?
  usedAt            DateTime?
  createdAt         DateTime  @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TherapeuticSession {
  id                String   @id @default(cuid())
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapistId       String
  therapist         User     @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  status            String   @default("active")
  phase             String   @default("character_creation")
  characterData     Json     @default("{}")
  currentRegion     String?
  currentHouseIndex Int      @default(0)
  unlockedTools     Json     @default("[]")
  completedRegions  Json     @default("[]")
  responses         Json     @default("[]")
  therapistNotes    String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
