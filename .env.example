# ─── Banco de dados (PostgreSQL / Supabase) ───
# DATABASE_URL: connection string da aplicação (pooler). DIRECT_URL: conexão
# direta usada por migrations / prisma db push.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── NextAuth ───
# Gere um secret forte e ÚNICO por ambiente: openssl rand -base64 48
NEXTAUTH_SECRET="CHANGE_ME_strong_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase (storage dos documentos de CRP) ───
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME_service_role_key"

# ─── Admin / controle de acesso ───
ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"
ADMIN_SECRET="CHANGE_ME_admin_secret"
CRON_SECRET="CHANGE_ME_cron_secret"
REGISTRATION_CODE="CHANGE_ME_registration_code"

# ─── E-mail (Gmail SMTP) ───
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="CHANGE_ME_gmail_app_password"
